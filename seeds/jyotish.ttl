# Aditya system — the 12 solar deities and their retinues of 84 beings.
# Extends the jyotish domain with the Aditya sign system (option 3: coexists
# with Rashi entities, same archetypal qualities, no explicit equivalence link).
#
# Structural data: Srimad Bhagavatam 12.11.33-44
# Compilation: Ernst Wilhelm, "The Adityas and Their Retinue"
# Subtitles and descriptions: Sunflare project

# ═══════════════════════════════════════════════════════════════════
# 1. Being Type Classes
# ═══════════════════════════════════════════════════════════════════

jyotish:AdityaBeing  a rdfs:Class ;
    rdfs:label   "aditya" ;
    rdfs:comment "Solar deity; son of Aditi, embodying a specific form of divine love, each driving the chariot of the Sun through one sign" .

jyotish:Rishi  a rdfs:Class ;
    rdfs:label   "rishi" ;
    rdfs:comment "Primordial seer who perceived the fundamental workings of Reality; reflects the innate Laws governing creation" .

jyotish:Gandharva  a rdfs:Class ;
    rdfs:label   "gandharva" ;
    rdfs:comment "Celestial musician and divine warrior; the sacred masculine force that motivates action and expression in the world" .

jyotish:Apsara  a rdfs:Class ;
    rdfs:label   "apsara" ;
    rdfs:comment "Celestial maiden governing subtle inner conditions; creates the mood and emotional catalyst necessary for expression" .

jyotish:Naga  a rdfs:Class ;
    rdfs:label   "naga" ;
    rdfs:comment "Primal life force bound to individual existence; the deep unconscious pull that leads all beings back to their spiritual source" .

jyotish:Yaksha  a rdfs:Class ;
    rdfs:label   "yaksha" ;
    rdfs:comment "Nature spirit whose mission is to differentiate; relates to the physical body and its unique expression" .

jyotish:RakshasaBeing  a rdfs:Class ;
    rdfs:label   "rakshasa" ;
    rdfs:comment "Protective force derived from raksh (to protect) that can go astray; represents the struggle to use power wisely without it becoming destructive" .

jyotish:DegreeRange  a rdfs:Class ;
    rdfs:label   "degree range" ;
    rdfs:comment "A degree range within a sign where a specific being is activated by the intersection of hora and trimsamsa" .

# ═══════════════════════════════════════════════════════════════════
# 2. Properties
# ═══════════════════════════════════════════════════════════════════

jyotish:subtitle       a rdf:Property ; rdfs:label "subtitle" .
jyotish:parity         a rdf:Property ; rdfs:label "parity" .
jyotish:hasRishi       a rdf:Property ; rdfs:domain jyotish:AdityaBeing ; rdfs:range jyotish:Rishi .
jyotish:hasGandharva   a rdf:Property ; rdfs:domain jyotish:AdityaBeing ; rdfs:range jyotish:Gandharva .
jyotish:hasApsara      a rdf:Property ; rdfs:domain jyotish:AdityaBeing ; rdfs:range jyotish:Apsara .
jyotish:hasNaga        a rdf:Property ; rdfs:domain jyotish:AdityaBeing ; rdfs:range jyotish:Naga .
jyotish:hasYaksha      a rdf:Property ; rdfs:domain jyotish:AdityaBeing ; rdfs:range jyotish:Yaksha .
jyotish:hasRakshasa    a rdf:Property ; rdfs:domain jyotish:AdityaBeing ; rdfs:range jyotish:RakshasaBeing .
jyotish:activatesBeingType  a rdf:Property ; rdfs:label "activates being type" .
jyotish:ofAditya       a rdf:Property ; rdfs:domain jyotish:DegreeRange ; rdfs:range jyotish:AdityaBeing .
jyotish:startDegree    a rdf:Property ; rdfs:domain jyotish:DegreeRange ; rdfs:range xsd:integer .
jyotish:endDegree      a rdf:Property ; rdfs:domain jyotish:DegreeRange ; rdfs:range xsd:integer .
jyotish:hora           a rdf:Property ; rdfs:domain jyotish:DegreeRange ; rdfs:range jyotish:Graha .
jyotish:trimsamsaLord  a rdf:Property ; rdfs:domain jyotish:DegreeRange ; rdfs:range jyotish:Graha .
jyotish:activeBeing    a rdf:Property ; rdfs:domain jyotish:DegreeRange .

# ═══════════════════════════════════════════════════════════════════
# 3. Traditions and Sources
# ═══════════════════════════════════════════════════════════════════

jyotish:tradition-aditya  a vidya:Tradition ;
    rdfs:label "aditya" .

jyotish:source-bhagavatam  a vidya:Source ;
    rdfs:label        "Srimad Bhagavatam" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.95"^^xsd:float ;
    rdfs:comment      "Srimad Bhagavatam 12.11.33-44" .

jyotish:source-ernst-wilhelm  a vidya:Source ;
    rdfs:label        "The Adityas and Their Retinue" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.9"^^xsd:float ;
    rdfs:comment      "Ernst Wilhelm, The Adityas and Their Retinue" .

# ═══════════════════════════════════════════════════════════════════
