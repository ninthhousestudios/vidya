@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix vidya:   <http://vidya.ninthhouse.studio/ontology/> .
@prefix jyotish: <http://vidya.ninthhouse.studio/domain/jyotish/> .

# ═══════════════════════════════════════════════════════════════════
# 1. Domain Classes and Properties
# ═══════════════════════════════════════════════════════════════════

jyotish:Graha       a rdfs:Class ; rdfs:label "graha"@sa .
jyotish:Rashi       a rdfs:Class ; rdfs:label "rashi"@sa .
jyotish:Bhava       a rdfs:Class ; rdfs:label "bhava"@sa .
jyotish:Nakshatra   a rdfs:Class ; rdfs:label "nakshatra"@sa .
jyotish:DignityType a rdfs:Class ; rdfs:label "dignitya"@sa .

# Entity attribute properties
jyotish:western         a rdf:Property ; rdfs:label "western name" .
jyotish:nature          a rdf:Property ; rdfs:label "nature" .
jyotish:gender          a rdf:Property ; rdfs:label "gender" .
jyotish:element         a rdf:Property ; rdfs:label "element" .
jyotish:tattva          a rdf:Property ; rdfs:label "tattva" .
jyotish:alias           a rdf:Property ; rdfs:label "alias" .
jyotish:signNumber      a rdf:Property ; rdfs:label "sign number" ; rdfs:range xsd:integer .
jyotish:quality         a rdf:Property ; rdfs:label "quality" .
jyotish:houseNumber     a rdf:Property ; rdfs:label "house number" ; rdfs:range xsd:integer .
jyotish:sanskritName    a rdf:Property ; rdfs:label "Sanskrit name" .
jyotish:signification   a rdf:Property ; rdfs:label "signification" .
jyotish:shadow          a rdf:Property ; rdfs:label "shadow planet" ; rdfs:range xsd:boolean .

# Relation properties
jyotish:rules           a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Rashi .
jyotish:exaltedIn       a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Rashi .
jyotish:debilitatedIn   a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Rashi .
jyotish:moolatrikonaIn  a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Rashi .
jyotish:naturalFriend   a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Graha .
jyotish:naturalEnemy    a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Graha .
jyotish:naturalNeutral  a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range jyotish:Graha .
jyotish:aspectsHouse    a rdf:Property ; rdfs:domain jyotish:Graha ; rdfs:range xsd:integer .
jyotish:karaka          a rdf:Property ; rdfs:domain jyotish:Graha .

# Provenance helper properties
jyotish:exaltationDegree    a rdf:Property ; rdfs:range xsd:integer .
jyotish:debilitationDegree  a rdf:Property ; rdfs:range xsd:integer .
jyotish:natureQualification a rdf:Property .

