# ═══════════════════════════════════════════════════════════════════
# 5. Dignity Type Entities
# ═══════════════════════════════════════════════════════════════════

jyotish:exaltation  a jyotish:DignityType ;
    rdfs:label           "Exaltation" ;
    jyotish:sanskritName "Uccha" ;
    rdfs:comment         "Planet at maximum strength and positive expression" .

jyotish:debilitation  a jyotish:DignityType ;
    rdfs:label           "Debilitation" ;
    jyotish:sanskritName "Nīcha" ;
    rdfs:comment         "Planet at minimum strength and challenged expression" .

jyotish:own-sign  a jyotish:DignityType ;
    rdfs:label           "Own Sign" ;
    jyotish:sanskritName "Svakṣetra" ;
    rdfs:comment         "Planet in a sign it rules, comfortable and strong" .

jyotish:moolatrikona  a jyotish:DignityType ;
    rdfs:label           "Mūlatrikoṇa" ;
    jyotish:sanskritName "Mūlatrikoṇa" ;
    rdfs:comment         "Planet in its office sign, strong in a specific degree range" .

# ═══════════════════════════════════════════════════════════════════
# 6. Traditions and Sources
# ═══════════════════════════════════════════════════════════════════

jyotish:tradition-parasara  a vidya:Tradition ;
    rdfs:label "parāśara" .

jyotish:tradition-jaimini  a vidya:Tradition ;
    rdfs:label "jaimini" .

jyotish:tradition-bphs  a vidya:Tradition ;
    rdfs:label              "bphs" ;
    vidya:parentTradition   jyotish:tradition-parasara .

jyotish:source-bphs  a vidya:Source ;
    rdfs:label        "Bṛhat Parāśara Horā Śāstra" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.95"^^xsd:float ;
    rdfs:comment      "Bṛhat Parāśara Horā Śāstra" .

jyotish:source-phala-dipika  a vidya:Source ;
    rdfs:label        "Phala Dīpikā" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.9"^^xsd:float ;
    rdfs:comment      "Phala Dīpikā (Mantreśvara)" .

jyotish:source-jataka-parijata  a vidya:Source ;
    rdfs:label        "Jātaka Pārijāta" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.9"^^xsd:float ;
    rdfs:comment      "Jātaka Pārijāta (Vaidyanātha)" .

jyotish:source-saravali  a vidya:Source ;
    rdfs:label        "Sārāvalī" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.9"^^xsd:float ;
    rdfs:comment      "Sārāvalī (Kalyāṇavarman)" .

# ═══════════════════════════════════════════════════════════════════
# 7. Relations as Simple Triples
# (All relations with provenance claims are expressed as RDF-star
#  annotations in Section 8 below; no bare duplicates here.)
# ═══════════════════════════════════════════════════════════════════

# — no additional bare triples needed; all covered by Section 8 —

# ═══════════════════════════════════════════════════════════════════
# 8. RDF-star Provenance Annotations
# ═══════════════════════════════════════════════════════════════════

# ── Dignity: Sūrya ──

<< jyotish:surya jyotish:exaltedIn jyotish:mesha >>
    jyotish:exaltationDegree 10 ;
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:surya jyotish:debilitatedIn jyotish:tula >>
    jyotish:debilitationDegree 10 ;
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:surya jyotish:rules jyotish:simha >>
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:surya jyotish:moolatrikonaIn jyotish:simha >>
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

# ── Dignity: Chandra ──

<< jyotish:chandra jyotish:exaltedIn jyotish:vrishabha >>
    jyotish:exaltationDegree 3 ;
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:chandra jyotish:debilitatedIn jyotish:vrischika >>
    jyotish:debilitationDegree 3 ;
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:chandra jyotish:rules jyotish:karka >>
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:chandra jyotish:moolatrikonaIn jyotish:vrishabha >>
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

# ── Dignity: Maṅgala ──

<< jyotish:mangala jyotish:exaltedIn jyotish:makara >>
    jyotish:exaltationDegree 28 ;
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:mangala jyotish:debilitatedIn jyotish:karka >>
    jyotish:debilitationDegree 28 ;
    vidya:assertedBy [
        vidya:tradition  jyotish:tradition-bphs ;
        vidya:source     jyotish:source-bphs ;
        vidya:pramana    vidya:shabda ;
        vidya:confidence "1.0"^^xsd:float
    ] .

<< jyotish:mangala jyotish:rules jyotish:mesha >>
    vidya:assertedBy [
