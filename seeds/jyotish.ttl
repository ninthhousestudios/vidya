    jyotish:subtitle "He Who Uses His Power Like the Sharpest Knife" .

jyotish:vishvavasu-parjanya  a jyotish:Gandharva ;
    rdfs:label       "Vishvavasu" ;
    jyotish:subtitle "The Sacred Masculine's Sacred Feminine" .

