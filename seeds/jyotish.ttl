jyotish:rahu  a jyotish:Graha ;
    rdfs:label      "Rāhu" ;
    jyotish:western "North Node" ;
    jyotish:nature  "malefic" ;
    jyotish:gender  "feminine" ;
    jyotish:shadow  true ;
    jyotish:alias   "North Node" ;
    jyotish:alias   "Dragon's Head" .

jyotish:ketu  a jyotish:Graha ;
