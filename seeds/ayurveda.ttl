# Illustrative ayurveda seed from LLM training data.
# Not authoritative -- verify against source texts before production use.
# Covers ~15 dravyas from dravyaguna shastra for demo purposes.

@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix vidya:    <http://vidya.ninthhouse.studio/ontology/> .
@prefix ayurveda: <http://vidya.ninthhouse.studio/domain/ayurveda/> .

# ═══════════════════════════════════════════════════════════════════
# 1. Domain Classes and Properties
# ═══════════════════════════════════════════════════════════════════

ayurveda:Dravya  a rdfs:Class ; rdfs:label "dravya" .
ayurveda:Rasa    a rdfs:Class ; rdfs:label "rasa" .
ayurveda:Guna    a rdfs:Class ; rdfs:label "guna" .
ayurveda:Dosha   a rdfs:Class ; rdfs:label "dosha" .
ayurveda:Karma   a rdfs:Class ; rdfs:label "karma" .

ayurveda:hasRasa          a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Rasa .
ayurveda:hasGuna          a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Guna .
ayurveda:hasVeerya        a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Guna .
ayurveda:hasVipaka        a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Rasa .
ayurveda:hasKarma         a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Karma .
ayurveda:pacifiesDosha    a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Dosha .
ayurveda:aggravatesDosha  a rdf:Property ; rdfs:domain ayurveda:Dravya ; rdfs:range ayurveda:Dosha .
ayurveda:oppositeGuna     a rdf:Property ; rdfs:domain ayurveda:Guna  ; rdfs:range ayurveda:Guna .
ayurveda:botanicalName    a rdf:Property ; rdfs:domain ayurveda:Dravya .
ayurveda:commonName       a rdf:Property ; rdfs:domain ayurveda:Dravya .

# Theory-level properties (rasa/guna → dosha)
ayurveda:aggravatesDosha  a rdf:Property .
ayurveda:pacifiesDosha    a rdf:Property .

# ═══════════════════════════════════════════════════════════════════
# 2. Rasa (6 tastes)
# ═══════════════════════════════════════════════════════════════════

ayurveda:madhura   a ayurveda:Rasa ; rdfs:label "madhura" ;  ayurveda:commonName "sweet" .
ayurveda:amla      a ayurveda:Rasa ; rdfs:label "amla" ;     ayurveda:commonName "sour" .
ayurveda:lavana    a ayurveda:Rasa ; rdfs:label "lavana" ;   ayurveda:commonName "salty" .
ayurveda:katu      a ayurveda:Rasa ; rdfs:label "katu" ;     ayurveda:commonName "pungent" .
ayurveda:tikta     a ayurveda:Rasa ; rdfs:label "tikta" ;    ayurveda:commonName "bitter" .
ayurveda:kashaya   a ayurveda:Rasa ; rdfs:label "kashaya" ;  ayurveda:commonName "astringent" .

# ═══════════════════════════════════════════════════════════════════
# 3. Guna (20 qualities in 10 opposing pairs)
# ═══════════════════════════════════════════════════════════════════

ayurveda:guru      a ayurveda:Guna ; rdfs:label "guru" ;     ayurveda:commonName "heavy" .
ayurveda:laghu     a ayurveda:Guna ; rdfs:label "laghu" ;    ayurveda:commonName "light" .
ayurveda:guru      ayurveda:oppositeGuna ayurveda:laghu .
ayurveda:laghu     ayurveda:oppositeGuna ayurveda:guru .

ayurveda:sheeta    a ayurveda:Guna ; rdfs:label "sheeta" ;   ayurveda:commonName "cold" .
ayurveda:ushna     a ayurveda:Guna ; rdfs:label "ushna" ;    ayurveda:commonName "hot" .
ayurveda:sheeta    ayurveda:oppositeGuna ayurveda:ushna .
ayurveda:ushna     ayurveda:oppositeGuna ayurveda:sheeta .

ayurveda:snigdha   a ayurveda:Guna ; rdfs:label "snigdha" ;  ayurveda:commonName "unctuous" .
ayurveda:ruksha    a ayurveda:Guna ; rdfs:label "ruksha" ;   ayurveda:commonName "dry" .
ayurveda:snigdha   ayurveda:oppositeGuna ayurveda:ruksha .
ayurveda:ruksha    ayurveda:oppositeGuna ayurveda:snigdha .

ayurveda:manda     a ayurveda:Guna ; rdfs:label "manda" ;    ayurveda:commonName "slow" .
ayurveda:tikshna   a ayurveda:Guna ; rdfs:label "tikshna" ;  ayurveda:commonName "sharp" .
ayurveda:manda     ayurveda:oppositeGuna ayurveda:tikshna .
ayurveda:tikshna   ayurveda:oppositeGuna ayurveda:manda .

ayurveda:sthira    a ayurveda:Guna ; rdfs:label "sthira" ;   ayurveda:commonName "stable" .
ayurveda:sara      a ayurveda:Guna ; rdfs:label "sara" ;     ayurveda:commonName "mobile" .
ayurveda:sthira    ayurveda:oppositeGuna ayurveda:sara .
ayurveda:sara      ayurveda:oppositeGuna ayurveda:sthira .

ayurveda:mridu     a ayurveda:Guna ; rdfs:label "mridu" ;    ayurveda:commonName "soft" .
ayurveda:kathina   a ayurveda:Guna ; rdfs:label "kathina" ;  ayurveda:commonName "hard" .
ayurveda:mridu     ayurveda:oppositeGuna ayurveda:kathina .
ayurveda:kathina   ayurveda:oppositeGuna ayurveda:mridu .

ayurveda:vishada   a ayurveda:Guna ; rdfs:label "vishada" ;  ayurveda:commonName "clear" .
ayurveda:picchila  a ayurveda:Guna ; rdfs:label "picchila" ; ayurveda:commonName "slimy" .
ayurveda:vishada   ayurveda:oppositeGuna ayurveda:picchila .
ayurveda:picchila  ayurveda:oppositeGuna ayurveda:vishada .

ayurveda:shlakshna a ayurveda:Guna ; rdfs:label "shlakshna" ; ayurveda:commonName "smooth" .
ayurveda:khara     a ayurveda:Guna ; rdfs:label "khara" ;     ayurveda:commonName "rough" .
ayurveda:shlakshna ayurveda:oppositeGuna ayurveda:khara .
ayurveda:khara     ayurveda:oppositeGuna ayurveda:shlakshna .

ayurveda:sukshma   a ayurveda:Guna ; rdfs:label "sukshma" ;  ayurveda:commonName "subtle" .
ayurveda:sthula    a ayurveda:Guna ; rdfs:label "sthula" ;   ayurveda:commonName "gross" .
ayurveda:sukshma   ayurveda:oppositeGuna ayurveda:sthula .
ayurveda:sthula    ayurveda:oppositeGuna ayurveda:sukshma .

ayurveda:sandra    a ayurveda:Guna ; rdfs:label "sandra" ;   ayurveda:commonName "dense" .
ayurveda:drava     a ayurveda:Guna ; rdfs:label "drava" ;    ayurveda:commonName "liquid" .
ayurveda:sandra    ayurveda:oppositeGuna ayurveda:drava .
ayurveda:drava     ayurveda:oppositeGuna ayurveda:sandra .

# ═══════════════════════════════════════════════════════════════════
# 4. Dosha (3)
# ═══════════════════════════════════════════════════════════════════

ayurveda:vata    a ayurveda:Dosha ; rdfs:label "vata" .
ayurveda:pitta   a ayurveda:Dosha ; rdfs:label "pitta" .
ayurveda:kapha   a ayurveda:Dosha ; rdfs:label "kapha" .

# ═══════════════════════════════════════════════════════════════════
# 5. Karma (actions, defined as-needed)
# ═══════════════════════════════════════════════════════════════════

ayurveda:deepana     a ayurveda:Karma ; rdfs:label "deepana" ;     ayurveda:commonName "appetizer" .
ayurveda:pachana     a ayurveda:Karma ; rdfs:label "pachana" ;     ayurveda:commonName "digestive" .
ayurveda:rasayana    a ayurveda:Karma ; rdfs:label "rasayana" ;    ayurveda:commonName "rejuvenative" .
ayurveda:anulomana   a ayurveda:Karma ; rdfs:label "anulomana" ;   ayurveda:commonName "carminative" .
ayurveda:medhya      a ayurveda:Karma ; rdfs:label "medhya" ;      ayurveda:commonName "brain tonic" .
ayurveda:balya       a ayurveda:Karma ; rdfs:label "balya" ;       ayurveda:commonName "strength-giving" .
ayurveda:shothahara  a ayurveda:Karma ; rdfs:label "shothahara" ;  ayurveda:commonName "anti-inflammatory" .
ayurveda:krimighna   a ayurveda:Karma ; rdfs:label "krimighna" ;   ayurveda:commonName "anthelmintic" .
ayurveda:jwaraghna   a ayurveda:Karma ; rdfs:label "jwaraghna" ;   ayurveda:commonName "antipyretic" .
ayurveda:vajikarana  a ayurveda:Karma ; rdfs:label "vajikarana" ;  ayurveda:commonName "aphrodisiac" .
ayurveda:virechana   a ayurveda:Karma ; rdfs:label "virechana" ;   ayurveda:commonName "purgative" .
ayurveda:medoghna    a ayurveda:Karma ; rdfs:label "medoghna" ;    ayurveda:commonName "fat-reducing" .
ayurveda:vatanulomana a ayurveda:Karma ; rdfs:label "vatanulomana" ; ayurveda:commonName "vata-directing" .

# ═══════════════════════════════════════════════════════════════════
# 6. Traditions and Sources
# ═══════════════════════════════════════════════════════════════════

ayurveda:tradition-ayurveda  a vidya:Tradition ;
    rdfs:label "ayurveda" .

ayurveda:tradition-atreya  a vidya:Tradition ;
    rdfs:label "atreya" ;
    vidya:parentTradition ayurveda:tradition-ayurveda .

ayurveda:tradition-dhanvantari  a vidya:Tradition ;
    rdfs:label "dhanvantari" ;
    vidya:parentTradition ayurveda:tradition-ayurveda .

ayurveda:source-charaka  a vidya:Source ;
    rdfs:label        "Charaka Samhita" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.95"^^xsd:float ;
    rdfs:comment      "Charaka Samhita (Atreya tradition)" .

ayurveda:source-sushruta  a vidya:Source ;
    rdfs:label        "Sushruta Samhita" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.95"^^xsd:float ;
    rdfs:comment      "Sushruta Samhita (Dhanvantari tradition)" .

ayurveda:source-bhavaprakasha  a vidya:Source ;
    rdfs:label        "Bhavaprakasha Nighantu" ;
    vidya:sourceKind  "text" ;
    vidya:reliability "0.9"^^xsd:float ;
    rdfs:comment      "Bhavaprakasha Nighantu (Bhavamishra, 16th century)" .

# ═══════════════════════════════════════════════════════════════════
# 7. Theory Triples: Rasa-to-Dosha Mappings
# ═══════════════════════════════════════════════════════════════════

# Madhura (sweet) — pacifies vata and pitta, aggravates kapha
ayurveda:madhura  ayurveda:pacifiesDosha   ayurveda:vata .
ayurveda:madhura  ayurveda:pacifiesDosha   ayurveda:pitta .
ayurveda:madhura  ayurveda:aggravatesDosha ayurveda:kapha .

# Amla (sour) — pacifies vata, aggravates pitta and kapha
ayurveda:amla     ayurveda:pacifiesDosha   ayurveda:vata .
ayurveda:amla     ayurveda:aggravatesDosha ayurveda:pitta .
ayurveda:amla     ayurveda:aggravatesDosha ayurveda:kapha .

# Lavana (salty) — pacifies vata, aggravates pitta and kapha
ayurveda:lavana   ayurveda:pacifiesDosha   ayurveda:vata .
ayurveda:lavana   ayurveda:aggravatesDosha ayurveda:pitta .
ayurveda:lavana   ayurveda:aggravatesDosha ayurveda:kapha .

# Katu (pungent) — pacifies kapha, aggravates vata and pitta
ayurveda:katu     ayurveda:pacifiesDosha   ayurveda:kapha .
ayurveda:katu     ayurveda:aggravatesDosha ayurveda:vata .
ayurveda:katu     ayurveda:aggravatesDosha ayurveda:pitta .

# Tikta (bitter) — pacifies pitta and kapha, aggravates vata
ayurveda:tikta    ayurveda:pacifiesDosha   ayurveda:pitta .
ayurveda:tikta    ayurveda:pacifiesDosha   ayurveda:kapha .
ayurveda:tikta    ayurveda:aggravatesDosha ayurveda:vata .

# Kashaya (astringent) — pacifies pitta and kapha, aggravates vata
ayurveda:kashaya  ayurveda:pacifiesDosha   ayurveda:pitta .
ayurveda:kashaya  ayurveda:pacifiesDosha   ayurveda:kapha .
ayurveda:kashaya  ayurveda:aggravatesDosha ayurveda:vata .

# ═══════════════════════════════════════════════════════════════════
# 8. Dravya Entities (15 substances)
# ═══════════════════════════════════════════════════════════════════

# ── 1. Haritaki ──
ayurveda:haritaki  a ayurveda:Dravya ;
    rdfs:label              "haritaki" ;
    ayurveda:commonName     "chebulic myrobalan" ;
    ayurveda:botanicalName  "Terminalia chebula" ;
    ayurveda:hasRasa        ayurveda:kashaya, ayurveda:tikta, ayurveda:madhura, ayurveda:katu, ayurveda:amla ;
    ayurveda:hasGuna        ayurveda:laghu, ayurveda:ruksha ;
    ayurveda:hasVeerya      ayurveda:ushna ;
    ayurveda:hasVipaka      ayurveda:madhura ;
    ayurveda:hasKarma       ayurveda:rasayana, ayurveda:anulomana, ayurveda:deepana ;
    ayurveda:pacifiesDosha  ayurveda:vata, ayurveda:pitta, ayurveda:kapha .

