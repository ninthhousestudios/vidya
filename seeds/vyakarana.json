    { "kind": "sutra", "name": "1.1.1", "attrs": { "text": "vṛddhir ādaic", "translation": "The vowels ā, ai, au are called vṛddhi" } },
    { "kind": "sutra", "name": "1.1.2", "attrs": { "text": "adeṅ guṇaḥ", "translation": "The vowels a, e, o are called guṇa" } },
    { "kind": "sutra", "name": "6.1.77", "attrs": { "text": "iko yaṇ aci", "translation": "An ik vowel is replaced by the corresponding yaṇ semivowel when followed by a vowel" } },
    { "kind": "sutra", "name": "6.1.78", "attrs": { "text": "eco'yavāyāvaḥ", "translation": "e and o are replaced by ay and av before a vowel" } },
    { "kind": "sutra", "name": "6.1.87", "attrs": { "text": "ād guṇaḥ", "translation": "When a/ā is followed by a simple vowel, guṇa replaces both" } },
    { "kind": "sutra", "name": "6.1.88", "attrs": { "text": "vṛddhir eci", "translation": "When a/ā is followed by e, o, ai, or au, vṛddhi replaces both" } },
    { "kind": "sutra", "name": "6.1.101", "attrs": { "text": "akaḥ savarṇe dīrghaḥ", "translation": "A simple vowel followed by its savarṇa (homogeneous vowel) is replaced by its long form" } },
    { "kind": "sutra", "name": "4.1.2", "attrs": { "text": "svaujasamauṭchaṣṭā...", "translation": "The sUP suffixes are ordained after nominal stems" } },
    { "kind": "sutra", "name": "6.1.103", "attrs": { "text": "tasmāc chasoḥ naḥ puṁsi", "translation": "After a-stem, śas is replaced by n in masculine" } },
    { "kind": "sutra", "name": "6.1.107", "attrs": { "text": "ami pūrvaḥ", "translation": "Before am pratyaya, the prior vowel prevails (absorbs the a of am)" } },
    { "kind": "sutra", "name": "6.1.69", "attrs": { "text": "eṅhrasvāt sambuddheh", "translation": "The su of sambodhana is deleted (luk) after a short vowel" } },
    { "kind": "sutra", "name": "7.1.9", "attrs": { "text": "ato bhisa ais", "translation": "After a-stem, bhis is replaced by ais" } },
    { "kind": "sutra", "name": "7.1.12", "attrs": { "text": "ṭānāsinasos tānāsināstasya...", "translation": "After a-stem, ṭā→ina, ṅasi→t, ṅas→sya" } },
    { "kind": "sutra", "name": "7.1.13", "attrs": { "text": "ṅe yaḥ", "translation": "After a-stem, ṅe is replaced by ya" } },
    { "kind": "sutra", "name": "7.1.54", "attrs": { "text": "hrasvanadasāpadeśasya nuṭ", "translation": "nuṬ augment is prefixed to am (gen pl) after short vowel" } },
    { "kind": "sutra", "name": "7.3.101", "attrs": { "text": "ato dīrgho yañi", "translation": "Final a of aṅga is lengthened before yaÑ-initial suffix" } },
    { "kind": "sutra", "name": "7.3.102", "attrs": { "text": "supi ca", "translation": "Extends 7.3.101 to sUP context" } },
    { "kind": "sutra", "name": "7.3.103", "attrs": { "text": "bahuvacane jhalyeṭ", "translation": "Final a of aṅga becomes e before jhaL-initial suffix in bahuvacana" } },
    { "kind": "sutra", "name": "7.3.104", "attrs": { "text": "osi ca", "translation": "Final a of aṅga becomes e before os (gen/loc dual)" } },
    { "kind": "sutra", "name": "8.2.66", "attrs": { "text": "sasajuṣo ruḥ", "translation": "Word-final s (and ṣ of sajuṣ) is replaced by ru (= r, u is it-marker)" } },
    { "kind": "sutra", "name": "8.3.15", "attrs": { "text": "kharavasānayorvisarjanīyaḥ", "translation": "r (from ru-substitution) becomes visarjanīya at avasāna (pause/word-end) or before khar consonant" } },
    { "kind": "sutra", "name": "8.3.59", "attrs": { "text": "ādeśapratyayoḥ", "translation": "s becomes ṣ after i/u/ṛ/e/o when in an ādeśa or pratyaya" } }
